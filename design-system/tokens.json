{
  "color": {
    "canvas": {
      "$value": "#fffaf0",
      "$type": "color",
      "description": "Cream-tinted white canvas - default page floor"
    },
    "primary": {
      "$value": "#0a0a0a",
      "$type": "color",
      "description": "Primary CTAs, h1/h2 ink type - near-black with slight warmth"
    },
    "brand-pink": {
      "$value": "#ff4d8b",
      "$type": "color",
      "description": "Hot-pink feature card surface"
    },
    "brand-teal": {
      "$value": "#1a3a3a",
      "$type": "color",
      "description": "Deep teal-green feature card"
    },
    "brand-lavender": {
      "$value": "#b8a4ed",
      "$type": "color",
      "description": "Soft lavender feature card"
    },
    "brand-peach": {
      "$value": "#ffb084",
      "$type": "color",
      "description": "Warm peach feature card"
    },
    "brand-ochre": {
      "$value": "#e8b94a",
      "$type": "color",
      "description": "Mustard/ochre feature card and illustration accents"
    },
    "brand-mint": {
      "$value": "#a4d4c5",
      "$type": "color",
      "description": "Mint accent on illustrations and small badges"
    },
    "brand-coral": {
      "$value": "#ff6b5a",
      "$type": "color",
      "description": "Coral accent for highlights"
    },
    "surface-soft": {
      "$value": "#faf5e8",
      "$type": "color",
      "description": "Footer and CTA-band background"
    },
    "surface-card": {
      "$value": "#f5f0e0",
      "$type": "color",
      "description": "Cream feature cards, testimonial cards"
    },
    "surface-strong": {
      "$value": "#ebe6d6",
      "$type": "color",
      "description": "Stronger cream for emphasized bands"
    },
    "surface-dark": {
      "$value": "#0a1a1a",
      "$type": "color",
      "description": "Dark teal-tinted near-black for occasional dark cards"
    },
    "surface-dark-elevated": {
      "$value": "#1a2a2a",
      "$type": "color",
      "description": "Elevated dark cards"
    },
    "hairline": {
      "$value": "#e5e5e5",
      "$type": "color",
      "description": "1px borders on cards and inputs"
    },
    "ink": {
      "$value": "#0a0a0a",
      "$type": "color",
      "description": "Headlines and primary text"
    },
    "body-strong": {
      "$value": "#1a1a1a",
      "$type": "color",
      "description": "Emphasized body, lead paragraphs"
    },
    "body": {
      "$value": "#3a3a3a",
      "$type": "color",
      "description": "Default running-text"
    },
    "muted": {
      "$value": "#6a6a6a",
      "$type": "color",
      "description": "Sub-headings, breadcrumbs, footer body"
    },
    "muted-soft": {
      "$value": "#9a9a9a",
      "$type": "color",
      "description": "Captions, fine-print"
    },
    "on-primary": {
      "$value": "#ffffff",
      "$type": "color",
      "description": "Text on primary buttons + dark feature cards"
    },
    "on-dark": {
      "$value": "#ffffff",
      "$type": "color",
      "description": "White text on dark feature cards (pink, teal)"
    },
    "success": {
      "$value": "#22c55e",
      "$type": "color",
      "description": "Success states"
    },
    "warning": {
      "$value": "#f59e0b",
      "$type": "color",
      "description": "Warning callouts"
    },
    "error": {
      "$value": "#ef4444",
      "$type": "color",
      "description": "Validation errors"
    }
  },
  "typography": {
    "display-xl": {
      "$value": {
        "fontFamily": "Plain Black, Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 500,
        "fontSize": "72px",
        "lineHeight": 1.0,
        "letterSpacing": "-2.5px"
      },
      "$type": "typography",
      "description": "Homepage h1 - Plain Black"
    },
    "display-lg": {
      "$value": {
        "fontFamily": "Plain Black, Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 500,
        "fontSize": "56px",
        "lineHeight": 1.05,
        "letterSpacing": "-2px"
      },
      "$type": "typography",
      "description": "Section heads - Plain Black"
    },
    "display-md": {
      "$value": {
        "fontFamily": "Plain Black, Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 500,
        "fontSize": "40px",
        "lineHeight": 1.1,
        "letterSpacing": "-1px"
      },
      "$type": "typography",
      "description": "Sub-section heads, product names"
    },
    "display-sm": {
      "$value": {
        "fontFamily": "Plain Black, Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 500,
        "fontSize": "32px",
        "lineHeight": 1.15,
        "letterSpacing": "-0.5px"
      },
      "$type": "typography",
      "description": "CTA-band heads, feature card titles"
    },
    "title-lg": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 600,
        "fontSize": "24px",
        "lineHeight": 1.3,
        "letterSpacing": "-0.3px"
      },
      "$type": "typography",
      "description": "Pricing plan names, larger feature titles"
    },
    "title-md": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 600,
        "fontSize": "18px",
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "description": "Card titles, intro paragraphs"
    },
    "title-sm": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 600,
        "fontSize": "16px",
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "description": "Small card titles, list labels"
    },
    "body-md": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 400,
        "fontSize": "16px",
        "lineHeight": 1.55,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "description": "Default running-text"
    },
    "body-sm": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 400,
        "fontSize": "14px",
        "lineHeight": 1.55,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "description": "Footer body, fine-print"
    },
    "caption": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 500,
        "fontSize": "13px",
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "description": "Badge labels, captions"
    },
    "caption-uppercase": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 600,
        "fontSize": "12px",
        "lineHeight": 1.4,
        "letterSpacing": "1.5px",
        "textTransform": "uppercase"
      },
      "$type": "typography",
      "description": "Section labels, 'FEATURED' badges"
    },
    "button": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 600,
        "fontSize": "14px",
        "lineHeight": 1.0,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "description": "Standard button labels"
    },
    "nav-link": {
      "$value": {
        "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontWeight": 500,
        "fontSize": "14px",
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "description": "Top-nav menu items"
    }
  },
  "spacing": {
    "xxs": {
      "$value": "4px",
      "$type": "spacing",
      "description": "Base unit"
    },
    "xs": {
      "$value": "8px",
      "$type": "spacing"
    },
    "sm": {
      "$value": "12px",
      "$type": "spacing"
    },
    "md": {
      "$value": "16px",
      "$type": "spacing"
    },
    "lg": {
      "$value": "24px",
      "$type": "spacing"
    },
    "xl": {
      "$value": "32px",
      "$type": "spacing",
      "description": "Card internal padding for feature cards and pricing tiers"
    },
    "xxl": {
      "$value": "48px",
      "$type": "spacing"
    },
    "section": {
      "$value": "96px",
      "$type": "spacing",
      "description": "Between major editorial bands"
    }
  },
  "borderRadius": {
    "xs": {
      "$value": "6px",
      "$type": "borderRadius",
      "description": "Small badges, dropdown items"
    },
    "sm": {
      "$value": "8px",
      "$type": "borderRadius",
      "description": "Small buttons, hairline-border accent"
    },
    "md": {
      "$value": "12px",
      "$type": "borderRadius",
      "description": "Standard CTA buttons, text inputs"
    },
    "lg": {
      "$value": "16px",
      "$type": "borderRadius",
      "description": "Content cards, testimonial cards, pricing tiers"
    },
    "xl": {
      "$value": "24px",
      "$type": "borderRadius",
      "description": "Feature cards (saturated brand-color cards)"
    },
    "pill": {
      "$value": "9999px",
      "$type": "borderRadius",
      "description": "Category tabs, badge pills"
    },
    "full": {
      "$value": "9999px",
      "$type": "borderRadius",
      "description": "Avatars, icon buttons (50% for circle)"
    }
  },
  "sizing": {
    "nav-height": {
      "$value": "64px",
      "$type": "sizing",
      "description": "Top navigation bar height"
    },
    "button-min-height": {
      "$value": "44px",
      "$type": "sizing",
      "description": "Minimum touch target height (WCAG AAA)"
    },
    "input-height": {
      "$value": "44px",
      "$type": "sizing",
      "description": "Text input field height"
    }
  },
  "layout": {
    "max-content-width": {
      "$value": "1280px",
      "$type": "dimension",
      "description": "Maximum content width, centered"
    },
    "grid-columns": {
      "$value": "12",
      "$type": "number",
      "description": "Standard 12-column grid"
    }
  },
  "component": {
    "button-primary": {
      "$value": {
        "backgroundColor": "{color.primary}",
        "color": "{color.on-primary}",
        "typography": "{typography.button}",
        "padding": "12px 20px",
        "height": "{sizing.button-min-height}",
        "borderRadius": "{borderRadius.md}"
      },
      "$type": "component"
    },
    "button-secondary": {
      "$value": {
        "backgroundColor": "{color.canvas}",
        "color": "{color.ink}",
        "border": "1px solid {color.hairline}",
        "borderRadius": "{borderRadius.md}",
        "padding": "12px 20px",
        "height": "{sizing.button-min-height}"
      },
      "$type": "component"
    },
    "text-input": {
      "$value": {
        "backgroundColor": "{color.canvas}",
        "color": "{color.ink}",
        "typography": "{typography.body-md}",
        "borderRadius": "{borderRadius.md}",
        "padding": "12px 16px",
        "height": "{sizing.input-height}",
        "border": "1px solid {color.hairline}"
      },
      "$type": "component"
    },
    "feature-card": {
      "$value": {
        "borderRadius": "{borderRadius.xl}",
        "padding": "{spacing.xl}"
      },
      "$type": "component",
      "description": "Base card - color variants applied via background"
    },
    "feature-card-pink": {
      "$value": {
        "backgroundColor": "{color.brand-pink}",
        "color": "{color.on-dark}"
      },
      "$type": "component"
    },
    "feature-card-teal": {
      "$value": {
        "backgroundColor": "{color.brand-teal}",
        "color": "{color.on-dark}"
      },
      "$type": "component"
    },
    "feature-card-lavender": {
      "$value": {
        "backgroundColor": "{color.brand-lavender}",
        "color": "{color.ink}"
      },
      "$type": "component"
    },
    "feature-card-peach": {
      "$value": {
        "backgroundColor": "{color.brand-peach}",
        "color": "{color.ink}"
      },
      "$type": "component"
    },
    "feature-card-ochre": {
      "$value": {
        "backgroundColor": "{color.brand-ochre}",
        "color": "{color.ink}"
      },
      "$type": "component"
    },
    "badge-pill": {
      "$value": {
        "backgroundColor": "{color.surface-card}",
        "typography": "{typography.caption}",
        "borderRadius": "{borderRadius.pill}",
        "padding": "4px 12px"
      },
      "$type": "component"
    }
  }
}