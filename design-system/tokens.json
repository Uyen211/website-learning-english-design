{
  "color": {
    "primary": {
      "$value": "#4E56C0",
      "$type": "color",
      "description": "Eternal night blue. For primary CTAs, active indicators."
    },
    "secondary": {
      "$value": "#9B5DE0",
      "$type": "color",
      "description": "Intellectual and whimsical purple. For secondary actions, icons."
    },
    "accent": {
      "$value": "#D78FEE",
      "$type": "color",
      "description": "A gentle, lighter purple for hover states."
    },
    "light-accent": {
      "$value": "#FDCFFA",
      "$type": "color",
      "description": "Warm, atmospheric pink for progress backgrounds and glows."
    },
    "canvas": {
      "$value": "#F9F7FE",
      "$type": "color",
      "description": "The main page background. A white with a very faint purple/pink tint."
    },
    "surface": {
      "$value": "#FFFFFF",
      "$type": "color",
      "description": "Pure white for content cards and panels."
    },
    "dark-floor": {
      "$value": "#1C1B2E",
      "$type": "color",
      "description": "A deep, dark blue-purple for the footer."
    },
    "glass": {
      "$value": "rgba(255, 255, 255, 0.7)",
      "$type": "color",
      "description": "Fill for glassmorphic elements."
    },
    "text-primary": {
      "$value": "#1A1A2E",
      "$type": "color",
      "description": "Near-black with a hint of blue for primary text."
    },
    "text-secondary": {
      "$value": "#5A5A7A",
      "$type": "color",
      "description": "Muted purple-gray for secondary text."
    },
    "on-primary": {
      "$value": "#FFFFFF",
      "$type": "color",
      "description": "White text for use on primary-colored buttons."
    },
    "success": {
      "$value": "#22C55E",
      "$type": "color",
      "description": "Success states."
    },
    "warning": {
      "$value": "#F59E0B",
      "$type": "color",
      "description": "Warning callouts."
    },
    "error": {
      "$value": "#EF4444",
      "$type": "color",
      "description": "Validation errors."
    }
  },
  "gradient": {
    "morning-nebula": {
      "$value": "linear-gradient(135deg, #FDCFFA 0%, #D78FEE 50%, #9B5DE0 100%)",
      "$type": "gradient"
    },
    "galactic-glow": {
      "$value": "linear-gradient(120deg, #4E56C0, #9B5DE0, #D78FEE)",
      "$type": "gradient"
    },
    "atmosphere-haze": {
      "$value": "radial-gradient(circle at 20% 30%, #FDCFFA, #F9F7FE)",
      "$type": "gradient"
    }
  },
  "boxShadow": {
    "glow-soft": {
      "$value": "0 0 12px rgba(155, 93, 224, 0.15)",
      "$type": "shadow"
    },
    "glow-normal": {
      "$value": "0 0 20px rgba(78, 86, 192, 0.25)",
      "$type": "shadow"
    },
    "glow-active": {
      "$value": "0 0 32px rgba(215, 143, 238, 0.4)",
      "$type": "shadow"
    }
  },
  "typography": {
    "font-primary": {
      "$value": "Manrope, sans-serif",
      "$type": "fontFamily"
    },
    "font-secondary": {
      "$value": "Inter, sans-serif",
      "$type": "fontFamily"
    },
    "display-xl": {
      "$value": {
        "fontFamily": "{typography.font-primary}",
        "fontWeight": 700,
        "fontSize": "64px",
        "lineHeight": 1.1,
        "letterSpacing": "-2px"
      },
      "$type": "typography"
    },
    "display-lg": {
      "$value": {
        "fontFamily": "{typography.font-primary}",
        "fontWeight": 700,
        "fontSize": "48px",
        "lineHeight": 1.15,
        "letterSpacing": "-1.5px"
      },
      "$type": "typography"
    },
    "display-md": {
      "$value": {
        "fontFamily": "{typography.font-primary}",
        "fontWeight": 700,
        "fontSize": "36px",
        "lineHeight": 1.2,
        "letterSpacing": "-1px"
      },
      "$type": "typography"
    },
    "display-sm": {
      "$value": {
        "fontFamily": "{typography.font-primary}",
        "fontWeight": 700,
        "fontSize": "28px",
        "lineHeight": 1.3,
        "letterSpacing": "-0.5px"
      },
      "$type": "typography"
    },
    "title-lg": {
      "$value": {
        "fontFamily": "{typography.font-secondary}",
        "fontWeight": 600,
        "fontSize": "24px",
        "lineHeight": 1.3,
        "letterSpacing": "0"
      },
      "$type": "typography"
    },
    "title-md": {
      "$value": {
        "fontFamily": "{typography.font-secondary}",
        "fontWeight": 600,
        "fontSize": "18px",
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "$type": "typography"
    },
    "body-md": {
      "$value": {
        "fontFamily": "{typography.font-secondary}",
        "fontWeight": 400,
        "fontSize": "16px",
        "lineHeight": 1.6,
        "letterSpacing": "0"
      },
      "$type": "typography"
    },
    "body-sm": {
      "$value": {
        "fontFamily": "{typography.font-secondary}",
        "fontWeight": 400,
        "fontSize": "14px",
        "lineHeight": 1.6,
        "letterSpacing": "0"
      },
      "$type": "typography"
    },
    "caption": {
      "$value": {
        "fontFamily": "{typography.font-secondary}",
        "fontWeight": 500,
        "fontSize": "12px",
        "lineHeight": 1.4,
        "letterSpacing": "0.5px"
      },
      "$type": "typography"
    },
    "button": {
      "$value": {
        "fontFamily": "{typography.font-secondary}",
        "fontWeight": 600,
        "fontSize": "16px",
        "lineHeight": 1.0,
        "letterSpacing": "0"
      },
      "$type": "typography"
    }
  },
  "spacing": {
    "xxs": { "$value": "4px", "$type": "spacing" },
    "xs": { "$value": "8px", "$type": "spacing" },
    "sm": { "$value": "12px", "$type": "spacing" },
    "md": { "$value": "16px", "$type": "spacing" },
    "lg": { "$value": "24px", "$type": "spacing" },
    "xl": { "$value": "32px", "$type": "spacing" },
    "xxl": { "$value": "48px", "$type": "spacing" },
    "section": { "$value": "96px", "$type": "spacing" }
  },
  "borderRadius": {
    "md": { "$value": "12px", "$type": "borderRadius" },
    "lg": { "$value": "16px", "$type": "borderRadius" },
    "xl": { "$value": "24px", "$type": "borderRadius" },
    "xxl": { "$value": "32px", "$type": "borderRadius" },
    "pill": { "$value": "9999px", "$type": "borderRadius" },
    "full": { "$value": "50%", "$type": "borderRadius" }
  },
  "sizing": {
    "nav-height": { "$value": "64px", "$type": "sizing" },
    "button-min-height": { "$value": "44px", "$type": "sizing" },
    "input-height": { "$value": "44px", "$type": "sizing" },
    "max-content-width": { "$value": "1200px", "$type": "dimension" }
  }
}